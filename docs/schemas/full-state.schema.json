{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindcraft.local/schemas/full-state.schema.json",
  "title": "Mindcraft Agent Full State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "gameplay",
    "action",
    "surroundings",
    "inventory",
    "nearby",
    "modes"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "gameplay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "position",
        "dimension",
        "gamemode",
        "health",
        "hunger",
        "biome",
        "weather",
        "timeOfDay",
        "timeLabel"
      ],
      "properties": {
        "position": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "z"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          }
        },
        "dimension": { "type": "string", "minLength": 1 },
        "gamemode": { "type": "string", "minLength": 1 },
        "health": { "type": "integer", "minimum": 0 },
        "hunger": { "type": "integer", "minimum": 0 },
        "biome": { "type": "string", "minLength": 1 },
        "weather": {
          "type": "string",
          "enum": ["Clear", "Rain", "Thunderstorm"]
        },
        "timeOfDay": { "type": "integer", "minimum": 0 },
        "timeLabel": {
          "type": "string",
          "enum": ["Morning", "Afternoon", "Night"]
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "isIdle"],
      "properties": {
        "current": { "type": "string" },
        "isIdle": { "type": "boolean" }
      }
    },
    "surroundings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["below", "legs", "head", "firstBlockAboveHead"],
      "properties": {
        "below": { "type": "string" },
        "legs": { "type": "string" },
        "head": { "type": "string" },
        "firstBlockAboveHead": {
          "type": ["string", "null"]
        }
      }
    },
    "inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["counts", "stacksUsed", "totalSlots", "equipment"],
      "properties": {
        "counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "stacksUsed": {
          "type": "integer",
          "minimum": 0
          },
        "totalSlots": {
          "type": "integer",
          "minimum": 0
        },
        "equipment": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "helmet",
            "chestplate",
            "leggings",
            "boots",
            "mainHand"
          ],
          "properties": {
            "helmet": { "type": ["string", "null"] },
            "chestplate": { "type": ["string", "null"] },
            "leggings": { "type": ["string", "null"] },
            "boots": { "type": ["string", "null"] },
            "mainHand": { "type": ["string", "null"] }
          }
        }
      }
    },
    "nearby": {
      "type": "object",
      "additionalProperties": false,
      "required": ["humanPlayers", "botPlayers", "entityTypes"],
      "properties": {
        "humanPlayers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "botPlayers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "entityTypes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "modes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string" }
      }
    }
  }
}
